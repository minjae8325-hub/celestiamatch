# Public site URL (used for OG + sitemap). Change after you buy your domain.
NEXT_PUBLIC_SITE_URL=https://celestiamatch.com

# Google AdSense publisher ID. Get from https://adsense.google.com
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=

# Optional: individual slot IDs if you want to override the defaults in lib/adSlots.ts
# NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
# NEXT_PUBLIC_ADSENSE_SLOT_RESULT_TOP=
# NEXT_PUBLIC_ADSENSE_SLOT_RESULT_MID=
# NEXT_PUBLIC_ADSENSE_SLOT_RESULT_BOTTOM=
# NEXT_PUBLIC_ADSENSE_SLOT_INFEED=
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
